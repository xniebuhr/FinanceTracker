{
  "name": "finance-tracker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "npx prettier --write ."
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
